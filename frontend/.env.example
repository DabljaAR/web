# Vite exposes only variables prefixed with VITE_ to the client bundle.

# Local dev: backend API (default in src/services/api.js when DEV is true)
VITE_API_BASE_URL=http://localhost:8000/api

# Production build behind same-origin reverse proxy (Caddy): relative URL so the SPA calls /api on the same host
# VITE_API_BASE_URL=/api
