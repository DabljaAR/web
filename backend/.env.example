# DabljaAR Backend Environment Configuration
# Copy this file to .env and customize for your environment

# ========== DATABASE ==========
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dabljaar

# ========== AUTHENTICATION ==========
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=300
REFRESH_TOKEN_EXPIRES_DAYS=7

# Auth0 / Social authentication (optional)
GOOGLE_REDIRECT_URL=
FACEBOOK_REDIRECT_URL=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# ========== MINIO / S3 STORAGE ==========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dablaja-videos
MINIO_SECURE=False

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_ENABLE_CONSOLE=True
LOG_ENABLE_FILE=True
LOG_JSON_FORMAT=False
LOG_ENABLE_SUCCESS=True

# ========== SPEECH-TO-TEXT (STT) ==========
# Model size: tiny, base, small, medium, large
# Recommendation: 'small' for balanced speed/quality, 'medium' for better quality
STT_MODEL_SIZE=small

# Device: cuda (GPU) or cpu
# Set to 'auto' for auto-detection (uses GPU if available, else CPU)
STT_DEVICE=auto

# Compute type: float32, float16, int8, int8_float32, int8_float16
# Set to 'auto' for auto-selection (float16 on GPU, int8 on CPU)
STT_COMPUTE_TYPE=auto

# Max concurrent transcriptions (1 = process one at a time)
STT_MAX_CONCURRENT=1

# Max audio duration in seconds (3600 = 1 hour)
STT_MAX_AUDIO_DURATION=3600

# Max file size in GB (5 = 5GB max)
STT_MAX_FILE_SIZE_GB=5

# GPU memory threshold (0.9 = 90%, reject requests above this)
STT_GPU_MEMORY_THRESHOLD=0.9

# Number of retries for failed transcriptions
STT_RETRY_ATTEMPTS=3

# Seconds between retries
STT_RETRY_DELAY=2

# ========== TEXT-TO-SPEECH (TTS - SILMA) ==========
# Device for SILMA-TTS: auto, cpu, cuda
# For GPU: set to 'cuda' and ensure CUDA is available
# For CPU: set to 'cpu' (works everywhere, slower)
SILMA_DEVICE=auto

# Reference audio for voice cloning (required)
# Path to a WAV or MP3 file (24kHz recommended)
SILMA_REFERENCE_AUDIO=/home/moustafa/Downloads/ar.ref.24k.wav

# Transcript of the reference audio (optional - auto-transcribed if not provided)
SILMA_REFERENCE_TEXT=    "ويدقق النظر في القرآن الكريم وسائر الكتب السماوية ويتبع مسالك الرسل العظام عليهم الصلاة والسلام.",

# TTS Quality Settings
TTS_DEFAULT_SPEED=1.0              # Speech rate (1.0 = normal, 0.8 = slower, 1.2 = faster)
TTS_DEFAULT_CFG_STRENGTH=1.0       # Guidance strength (1.0-1.5 recommended)
TTS_DEFAULT_NFE_STEP=32            # Quality steps (32 = fast, 40+ = higher quality)
TTS_DEFAULT_SWAY_COEF=-1.0         # Sway sampling coefficient
TTS_DEFAULT_TARGET_RMS=0.12        # Audio normalization level

# Temporary directory for TTS files (defaults to system temp)
# TTS_TEMP_DIR=/tmp

# ========== NEURAL MACHINE TRANSLATION (NMT) ==========
# MinIO bucket that holds the custom NMT model (must exist before first run)
NMT_MODEL_BUCKET=model
# Object key / prefix inside the bucket (the folder you uploaded the model to)
NMT_MODEL_KEY=nmt-v4
# Absolute path inside the container where the model is cached between restarts
NMT_MODEL_LOCAL_PATH=/model-cache/nmt-v4
# HuggingFace model id used if MinIO download fails or is not configured
NMT_HF_FALLBACK=facebook/nllb-200-distilled-600M
# HuggingFace token — required only for private/gated models
HF_TOKEN=

# ========== CELERY / REDIS ==========
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
WORKER_CONCURRENCY=2

# ========== SERVER ==========
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ========== ENVIRONMENT ==========
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=True