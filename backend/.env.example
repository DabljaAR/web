# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_ENABLE_CONSOLE=True
LOG_ENABLE_FILE=True
LOG_JSON_FORMAT=False
LOG_ENABLE_SUCCESS=True


# ========== SPEECH-TO-TEXT (STT) ==========
# Model size: tiny, base, small, medium, large
# Recommendation: 'small' for balanced speed/quality
STT_MODEL_SIZE=small

# Device: cuda (GPU) or cpu
# Set to 'auto' for auto-detection (uses GPU if available, else CPU)
STT_DEVICE=auto

# Compute type: float32, float16, int8, int8_float32, int8_float16
# Set to 'auto' for auto-selection (float16 on GPU, int8 on CPU)
STT_COMPUTE_TYPE=auto

# Max concurrent transcriptions (1 = process one at a time)
STT_MAX_CONCURRENT=1

# Max audio duration in seconds (3600 = 1 hour)
STT_MAX_AUDIO_DURATION=3600

# Max file size in GB (5 = 5GB max)
STT_MAX_FILE_SIZE_GB=5

# GPU memory threshold (0.9 = 90%, reject requests above this)
STT_GPU_MEMORY_THRESHOLD=0.9

# Number of retries for failed transcriptions
STT_RETRY_ATTEMPTS=3

# Seconds between retries
STT_RETRY_DELAY=2

# ========== SERVER ==========
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ========== ENVIRONMENT ==========
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=True
