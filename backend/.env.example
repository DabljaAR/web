# DabljaAR Backend Environment Configuration
# Copy this file to .env in this directory (backend/) when running the API outside Docker.
# Docker Compose at repo root does not load this file for interpolation; see root .env.example.

# ========== DATABASE ==========
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dabljaar

# ========== AUTHENTICATION ==========
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300
REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth0 / Social authentication (optional)
GOOGLE_REDIRECT_URL=
FACEBOOK_REDIRECT_URL=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# ========== STORAGE ==========
# Choices: "local" | "s3"
# Default if unset: "s3" when MINIO_ENDPOINT is set in the environment, else "local"
STORAGE_BACKEND=s3

# Preferred: generic S3 API (MinIO, AWS S3, GCP interop). S3_* override MINIO_* when set.
# Leave S3_ENDPOINT_URL empty for AWS S3 default routing.
# MinIO local: http://localhost:9000 — Docker service: http://minio:9000
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Primary bucket controls (may be the same bucket name):
#   S3_MEDIA_BUCKET — user uploads, HLS, presigned URLs, TTS output keys, etc.
#   S3_MODELS_BUCKET — NMT weights (and future STT/TTS artifacts in object storage)
S3_MEDIA_BUCKET=dablaja-videos
S3_MODELS_BUCKET=model
# Legacy fallbacks if S3_MEDIA_BUCKET / S3_MODELS_BUCKET are unset:
S3_BUCKET_NAME=dablaja-videos
S3_REGION=
S3_SECURE=False

# Legacy MinIO names — used only when the corresponding S3_* value is unset
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dablaja-videos
MINIO_SECURE=False

# When STORAGE_BACKEND=local, files live under LOCAL_STORAGE_DIR
LOCAL_STORAGE_DIR=uploads
LOCAL_STORAGE_URL_PREFIX=/uploads

# --- Example: GCP Cloud Storage (S3 interoperability HMAC keys) ---
# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=https://storage.googleapis.com
# S3_ACCESS_KEY_ID=<HMAC access key>
# S3_SECRET_ACCESS_KEY=<HMAC secret>
# S3_BUCKET_NAME=your-gcs-bucket
# S3_REGION=auto

# --- Example: AWS S3 ---
# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=<IAM access key>
# S3_SECRET_ACCESS_KEY=<IAM secret>
# S3_BUCKET_NAME=your-s3-bucket
# S3_REGION=us-east-1
# S3_SECURE=true

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_ENABLE_CONSOLE=True
# Set False in production for stdout-only (12-factor)
LOG_TO_FILE=True
LOG_JSON_FORMAT=False
LOG_ENABLE_SUCCESS=True

# ========== SPEECH-TO-TEXT (STT) ==========
STT_MODEL_SIZE=small
# Optional: pull CTranslate2 / faster-whisper weights from S3_MODELS_BUCKET into STT_MODEL_LOCAL_PATH.
# STORAGE_BACKEND must be s3. Layout under the models bucket, e.g. prefix whisper-small/:
#   model.bin, config.json, vocabulary.txt, tokenizer.json (same layout as Systran/faster-whisper-* on Hugging Face).
# If the prefix is missing or empty, the worker falls back to Hugging Face (first load can take many minutes).
STT_MODEL_KEY=
STT_MODEL_LOCAL_PATH=
# Hugging Face cache + Hub behavior (AI worker / any process that downloads models):
# Point HF_HOME at a persistent directory (e.g. /model-cache/hf in Docker) so weights survive container restarts.
# HF_HOME=
# If Hub downloads hang after xet-read-token, try disabling Xet (see huggingface_hub release notes / issues).
# HF_HUB_DISABLE_XET=1
# Optional faster parallel downloads when using the Hub.
# HF_HUB_ENABLE_HF_TRANSFER=1
# For non-root containers, keep all AI caches under a writable path.
# HF_HOME=/model-cache/hf
# HUGGINGFACE_HUB_CACHE=/model-cache/hf/hub
# TRANSFORMERS_CACHE=/model-cache/hf/transformers
# XDG_CACHE_HOME=/model-cache/xdg-cache
# TORCH_HOME=/model-cache/torch
# CATT_TASHKEEL_MODEL_DIR=/model-cache/catt_tashkeel/onnx_models
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto
STT_MAX_CONCURRENT=1
STT_MAX_AUDIO_DURATION=3600
STT_MAX_FILE_SIZE_GB=5
STT_GPU_MEMORY_THRESHOLD=0.9
STT_RETRY_ATTEMPTS=3
STT_RETRY_DELAY=2

# ========== TEXT-TO-SPEECH (TTS — SILMA) ==========
SILMA_DEVICE=auto
# Path to reference WAV/MP3, or S3 object key in S3_MEDIA_BUCKET when STORAGE_BACKEND=s3
SILMA_REFERENCE_AUDIO=
# Optional transcript of reference audio (auto-transcribed if empty)
# Bundled ar.ref.24k.wav default below — override to match your own reference audio
SILMA_REFERENCE_TEXT=ويدقق النظر في القرآن الكريم وسائر الكتب السماوية ويتبع مسالك الرسل العظام عليهم الصلاة والسلام.

# Speech rate (0.9 = slightly slower; more natural Arabic pacing)
TTS_DEFAULT_SPEED=0.9
# Guidance strength (2.0 = F5-TTS paper default; 1.0 too weak for Arabic)
TTS_DEFAULT_CFG_STRENGTH=2.0
# Quality steps (64 = fewer robotic artifacts; 32 = faster but lower quality)
TTS_DEFAULT_NFE_STEP=64
TTS_DEFAULT_SWAY_COEF=-1.0
TTS_DEFAULT_TARGET_RMS=0.12

# ========== NEURAL MACHINE TRANSLATION (NMT) ==========
# Bucket for model files: S3_MODELS_BUCKET (or legacy NMT_MODEL_BUCKET). Prefix inside bucket:
NMT_MODEL_KEY=nmt-v4
NMT_MODEL_LOCAL_PATH=/model-cache/nmt-v4
NMT_HF_FALLBACK=facebook/nllb-200-distilled-600M
HF_TOKEN=

# ========== CELERY / REDIS ==========
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
WORKER_CONCURRENCY=2

# ========== SERVER ==========
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ========== ENVIRONMENT ==========
ENVIRONMENT=development
DEBUG=True

# ========== OPTIONAL (Docker / feature gates) ==========
# Heavy AI dependencies in API image and Celery (see Dockerfile args and celery_app)
INSTALL_AI=false
# Default-only pipeline mode toggle.
# true: captionsOnly/captionsAndTranslation/translationAndTTS/fullDubbing default to single-chunk processing.
# false: keep current segmented processing.
PIPELINE_USE_SINGLE_CHUNK=false
