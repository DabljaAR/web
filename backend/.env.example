# DabljaAR Backend Environment Configuration
# Copy this file to .env and customize for your environment

# ========== DATABASE ==========
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dabljaar

# ========== AUTHENTICATION ==========
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=300
REFRESH_TOKEN_EXPIRES_DAYS=7

# Auth0 / Social authentication (optional)
GOOGLE_REDIRECT_URL=
FACEBOOK_REDIRECT_URL=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# ========== MINIO / S3 STORAGE ==========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dablaja-videos
MINIO_SECURE=False

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_ENABLE_CONSOLE=True
LOG_ENABLE_FILE=True
LOG_JSON_FORMAT=False
LOG_ENABLE_SUCCESS=True

# ========== SPEECH-TO-TEXT (STT) ==========
# Model size: tiny, base, small, medium, large
# Recommendation: 'small' for balanced speed/quality, 'medium' for better quality
STT_MODEL_SIZE=small

# Device: cuda (GPU) or cpu
# Set to 'auto' for auto-detection (uses GPU if available, else CPU)
STT_DEVICE=auto

# Compute type: float32, float16, int8, int8_float32, int8_float16
# Set to 'auto' for auto-selection (float16 on GPU, int8 on CPU)
STT_COMPUTE_TYPE=auto

# Max concurrent transcriptions (1 = process one at a time)
STT_MAX_CONCURRENT=1

# Max audio duration in seconds (3600 = 1 hour)
STT_MAX_AUDIO_DURATION=3600

# Max file size in GB (5 = 5GB max)
STT_MAX_FILE_SIZE_GB=5

# GPU memory threshold (0.9 = 90%, reject requests above this)
STT_GPU_MEMORY_THRESHOLD=0.9

# Number of retries for failed transcriptions
STT_RETRY_ATTEMPTS=3

# Seconds between retries
STT_RETRY_DELAY=2

# ========== TEXT-TO-SPEECH (TTS) ==========
# Device for Habibi-TTS: auto, cpu, cuda
# For GPU: set to 'cuda' and install torch with CUDA support
# For CPU: set to 'cpu' (default, works everywhere)
HABIBI_DEVICE=auto

# Habibi-TTS paths (leave empty for auto-detection)
# Only set these if you have custom installations
# HABIBI_TTS_SRC=/path/to/habibi-tts/src
# HABIBI_MODEL_PATH=/path/to/huggingface/cache
# HABIBI_REFERENCE_AUDIO=/path/to/custom/reference.wav

# TTS Speed Control
# 1.0 = normal speed, 0.8 = slower/clearer, 1.3 = faster
# Range: 0.5 (very slow) to 2.0 (very fast)
TTS_DEFAULT_SPEED=0.8

# TTS Quality/Guidance Strength 
# Higher values = more guided/consistent, but slower
# Range: 1.0 (weak) to 7.0 (strong), default: 3.0
TTS_DEFAULT_CFG_STRENGTH=3.0

# Temporary directory for TTS files (defaults to system temp)
# TTS_TEMP_DIR=/tmp

# ========== CELERY / REDIS ==========
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
WORKER_CONCURRENCY=2

# ========== SERVER ==========
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ========== ENVIRONMENT ==========
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=True