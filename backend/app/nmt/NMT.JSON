{
    "info": {
        "_postman_id": "7d9c6f2a-8b3a-4e2b-9a3c-1d2e3f4g5h6i",
        "name": "DabljaAR NMT API",
        "description": "Postman collection for testing the Neural Machine Translation service.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "NMT",
            "item": [
                {
                    "name": "Translate Direct Script",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"text\": \"Artificial intelligence is transforming the way we interact with technology. It is a very long text and should be translated correctly.\",\n    \"target_lang\": \"arb_Arab\",\n    \"source_lang\": null\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/nmt/translate-script",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "nmt",
                                "translate-script"
                            ]
                        },
                        "description": "Send a direct text script for translation. Language is detected automatically if source_lang is null."
                    },
                    "response": []
                },
                {
                    "name": "Create Translation for Video",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/videos/{{video_id}}/translate?target_lang=arb_Arab",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "videos",
                                "{{video_id}}",
                                "translate"
                            ],
                            "query": [
                                {
                                    "key": "target_lang",
                                    "value": "arb_Arab"
                                }
                            ]
                        },
                        "description": "Starts a translation job for an existing text video."
                    },
                    "response": []
                },
                {
                    "name": "Get Translation Job Status",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/nmt/jobs/{{job_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "nmt",
                                "jobs",
                                "{{job_id}}"
                            ]
                        },
                        "description": "Check the status of a translation job and get the URLs for the source and translated files."
                    },
                    "response": []
                },
                {
                    "name": "List Video Translations",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/videos/{{video_id}}/translations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "videos",
                                "{{video_id}}",
                                "translations"
                            ]
                        },
                        "description": "Get all translation jobs associated with a specific video."
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000"
        },
        {
            "key": "access_token",
            "value": "YOUR_ACCESS_TOKEN_HERE"
        },
        {
            "key": "video_id",
            "value": "VIDEO_UUID_HERE"
        },
        {
            "key": "job_id",
            "value": "JOB_UUID_HERE"
        }
    ]
}
