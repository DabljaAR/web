# Repo root — Docker Compose variable substitution only.
# Compose loads this file automatically as the default env file (not passed into containers unless referenced below).
# Backend settings when running `uvicorn` locally: see backend/.env.example (file: backend/.env).
# Frontend Vite dev server: see frontend/.env.example (file: frontend/.env).

# --- Used by docker-compose.yml (${VAR} interpolation) ---
SECRET_KEY=your-secret-key-change-this-in-production
STORAGE_BACKEND=s3
VITE_API_BASE_URL=http://localhost:8000/api

# AI worker (celery-worker-ai) optional overrides
NMT_MODEL_BUCKET=model
NMT_MODEL_KEY=nmt-v4
NMT_HF_FALLBACK=facebook/nllb-200-distilled-600M
HF_TOKEN=

# --- Not read by compose services (local tooling / documentation only) ---
# DATABASE_URL and PORT apply if you run the backend outside Compose from a shell that loads this file;
# the backend also loads backend/.env when started from the backend directory.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/dabljaar
PORT=8000

# MinIO client-style vars (match docker-compose.yml defaults unless you use a custom bucket name)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dablaja-videos
MINIO_SECURE=false

# Celery / Redis (for local workers not using compose env blocks)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
WORKER_CONCURRENCY=2

# JWT (backend reads from its own process env; compose dev stack sets these inline)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
