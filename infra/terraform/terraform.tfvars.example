# =============================================================================
# DabljaAR Terraform Configuration Example
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Required: GCP Project Configuration
# -----------------------------------------------------------------------------
project_id   = "your-gcp-project-id"    # Your GCP project ID
project_name = "dabljaar"                # Short name for resources
environment  = "dev"                     # dev, staging, or prod

# -----------------------------------------------------------------------------
# Required: Region & Zone
# -----------------------------------------------------------------------------
# Choose a region with T4 GPUs available
# See: https://cloud.google.com/compute/docs/gpus/gpu-regions-zones
region = "us-central1"
zone   = "us-central1-a"

# -----------------------------------------------------------------------------
# Optional: Network Configuration
# -----------------------------------------------------------------------------
subnet_cidr = "10.0.0.0/24"

# Admin access (SSH, Flower, MinIO console)
# Add your IP: curl ifconfig.me
admin_cidr_blocks = [
  # "YOUR_IP/32",     # Your home IP
  # "OFFICE_IP/32",   # Office IP
]

# Public ports (Caddy TLS termination)
public_ports = [80, 443]

# Admin ports reachable only from admin_cidr_blocks
# SSH is handled separately via IAP firewall rule in this module.
admin_ports = [5555, 9001]

# -----------------------------------------------------------------------------
# Optional: Compute Configuration
# -----------------------------------------------------------------------------
machine_type   = "n1-standard-4"     # 4 vCPU, 15GB RAM
gpu_type       = "nvidia-tesla-t4"   # 16GB VRAM
gpu_count      = 0
enable_spot    = true                # ~70% cost savings
startup_script_enabled = false       # Set true to install Docker + host baseline at first boot
deployment_user = "ubuntu"          # Ownership for /opt/web paths created by bootstrap
enable_vm_service_account = false    # Set true to create and attach a dedicated VM SA
# vm_env_secret_name = "env-production"  # Optional: secret containing full .env.production text
# vm_git_deploy_key_secret_name = "github-deploy-key"  # Optional: secret containing private deploy key for git clone
# vm_service_account_roles = [        # Optional override
#   "roles/logging.logWriter",
#   "roles/monitoring.metricWriter",
#   "roles/secretmanager.secretAccessor"
# ]
# vm_service_account_scopes = ["https://www.googleapis.com/auth/cloud-platform"]
boot_disk_image = "projects/deeplearning-platform-release/global/images/family/common-cu128-ubuntu-2204-nvidia-570"
boot_disk_size = 50                  # GB
data_disk_size = 100                 # GB (persistent)

# -----------------------------------------------------------------------------
# Optional: Storage Configuration
# -----------------------------------------------------------------------------
# Bucket is created automatically in the selected region by the storage module.
