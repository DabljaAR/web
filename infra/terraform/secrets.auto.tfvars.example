# Optional: override default secret file paths (literals only — no file() in .tfvars).
#
# env_production_file    = "/absolute/path/to/.env.production"
# github_deploy_key_file = "/absolute/path/to/github_deploy_key"
#
# Defaults (when unset) are loaded in locals.tf via file():
#   ${path.root}/../../.env.production
#   ${path.root}/../../../keys/github_deploy_key
