# Copy to .env.production and fill in secrets. Used by:
#   docker compose --env-file .env.production -f docker-compose.microservices.prod.yml up -d --build
# Keep .env.production out of version control.

# Legacy Celery stack (deprecated):
#   docker compose -f docker-compose.prod.minimal.yml --env-file .env.production up -d --build

# =============================================================================
# Caddy / domain
# =============================================================================
DOMAIN=app.yourbrand.tech
ACME_EMAIL=you@yourbrand.tech

# =============================================================================
# RabbitMQ (required for dubbing pipeline — job.created / orchestrator)
# =============================================================================
RABBITMQ_DEFAULT_USER=dabljaar
RABBITMQ_DEFAULT_PASS=replace-with-strong-password
# URL must match credentials above (used by backend + workers + orchestrator)
RABBITMQ_URL=amqp://dabljaar:replace-with-strong-password@rabbitmq:5672/

# Legacy Flower (only for docker-compose.prod.minimal.yml — not used in microservices prod)
# FLOWER_BASIC_AUTH=admin:replace-with-strong-password

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=dabljaar

# =============================================================================
# MinIO (in-stack container credentials; compose maps these to MINIO_ACCESS_KEY / MINIO_SECRET_KEY for app workers)
# =============================================================================
MINIO_ROOT_USER=replace-with-access-key
MINIO_ROOT_PASSWORD=replace-with-secret-key
MINIO_BUCKET_NAME=dablaja-videos
# Optional explicit buckets (defaults: media = MINIO_BUCKET_NAME or dablaja-videos, models = model)
S3_MEDIA_BUCKET=your-media-bucket
# Terraform creates dabljaar-prod-models-XXXX — set after first apply: terraform output -raw storage_bucket_name
S3_MODELS_BUCKET=replace-after-terraform-apply

# =============================================================================
# Object storage — external S3/GCS (microservices prod uses these for all workers)
# =============================================================================
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://storage.googleapis.com
S3_ACCESS_KEY_ID=
# If the secret contains + or /, wrap the value in double quotes in .env files.
S3_SECRET_ACCESS_KEY=
# GCS HMAC SigV4: use us-east-1 (GCS convention). AWS S3: use your bucket region.
S3_REGION=us-east-1
S3_SECURE=true

# =============================================================================
# Celery workers (legacy docker-compose.prod.minimal.yml only — not microservices prod)
# =============================================================================
MEDIA_WORKER_CONCURRENCY=2
AI_WORKER_CONCURRENCY=1

# =============================================================================
# NMT — object prefix under S3_MODELS_BUCKET (cached under nmt_model_cache volume on first start)
# =============================================================================
NMT_MODEL_KEY=nmt-v4
NMT_MODEL_LOCAL_PATH=/model-cache/nmt-v4
NMT_HF_FALLBACK=facebook/nllb-200-distilled-600M
# stage2_only: stop after stage-2 retry
# stage3_updated: continue to stage-3 only when updated Arabic/mixed-token score is high
NMT_FALLBACK_MODE=stage2_only
HF_TOKEN=

# NMT length adjustment — adjusts Arabic translation length to match English speaking duration.
# Requires a Groq API key (https://console.groq.com). Leave GROQ_API_KEY empty to disable.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
NMT_LENGTH_ADJUST_ENABLED=true
NMT_LENGTH_ADJUST_SCALE=0.9
NMT_LENGTH_ADJUST_MAX_ITERS=5
HF_HUB_DISABLE_XET=1
HF_HUB_DOWNLOAD_TIMEOUT=120

# Keep caches/models under writable mounted storage for non-root workers.
HF_HOME=/model-cache/hf
HUGGINGFACE_HUB_CACHE=/model-cache/hf/hub
TRANSFORMERS_CACHE=/model-cache/hf/transformers
XDG_CACHE_HOME=/model-cache/xdg-cache
TORCH_HOME=/model-cache/torch
CATT_TASHKEEL_MODEL_DIR=/model-cache/catt_tashkeel/onnx_models

# =============================================================================
# STT (Whisper / faster-whisper) — prefix under S3_MODELS_BUCKET, then HuggingFace by STT_MODEL_SIZE
# With docker-compose.gpu.yml use cuda + STT_COMPUTE_TYPE=float16
# =============================================================================
STT_MODEL_SIZE=medium
STT_MODEL_KEY=whisper-medium
STT_MODEL_LOCAL_PATH=/model-cache/whisper-medium
STT_DEVICE=cpu
STT_COMPUTE_TYPE=auto

# =============================================================================
# TTS / SILMA — SILMA_REFERENCE_AUDIO: container filesystem path OR S3 object key in S3_MEDIA_BUCKET
# =============================================================================
SILMA_DEVICE=cpu
SILMA_REFERENCE_AUDIO=
SILMA_REFERENCE_TEXT="Redis، قاعدة بيانات متعددة النماذج داخل الذاكرة مشهورة بتخفيتها دون الأملث الثانية. أنشئت في عام 2009، استنادا إلى فكرة أن الاحتياطي السري يمكن أن يكون أيضا مخزن للبيانات الدائمة. في هذا الوقت، كانت التطبيقات مثل تويتر تنمو بصورة متسارعة ويحتاجت إلى وسيلة لتوصيل البيانات إلى مستخدميها النهائيين بسرعة أكبر من ما يمكن قاعدة بيانات علاقية أن تتعامل معه"
TTS_DEFAULT_SPEED=0.9
TTS_DEFAULT_CFG_STRENGTH=2.0
TTS_DEFAULT_NFE_STEP=64
TTS_DEFAULT_SWAY_COEF=-1.0
TTS_DEFAULT_TARGET_RMS=0.12
TTS_ENABLE_NORMALIZER=true
TTS_FORCE_TASHKEEL=false

# stt_focused: keep original segments generated by stt
# single: run all segments through the pipeline as a single chunk
# tts_focused: rebuild segments from words for better TTS output (experimental; may cause issues with timing and NMT)
PIPELINE_SEGMENTS_MODE=single
DUBBING_MERGE_PATH=/tmp/dubbing_merge
