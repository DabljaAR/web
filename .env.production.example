# Copy to .env.production and fill in secrets. Used by: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production
# Keep .env.production out of version control.

# Caddy / domain
DOMAIN=example.com
ACME_EMAIL=ops@example.com

# Core security
SECRET_KEY=replace-with-long-random-secret

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=dabljaar

# MinIO container root credentials (compose maps these to MINIO_ACCESS_KEY / MINIO_SECRET_KEY for app workers)
MINIO_ROOT_USER=replace-with-access-key
MINIO_ROOT_PASSWORD=replace-with-secret-key
MINIO_BUCKET_NAME=dablaja-videos
# Explicit buckets (optional; default media = MINIO_BUCKET_NAME, models = model)
S3_MEDIA_BUCKET=
S3_MODELS_BUCKET=

# Optional auth tuning
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Object storage — optional overrides for external S3/GCP (in-stack MinIO uses compose defaults for endpoint and keys)
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=dablaja-videos
S3_REGION=
S3_SECURE=false

# NMT model — object prefix under S3_MODELS_BUCKET (downloaded to nmt_model_cache volume on first start)
NMT_MODEL_KEY=nmt-v4
NMT_MODEL_LOCAL_PATH=/model-cache/nmt-v4
NMT_HF_FALLBACK=facebook/nllb-200-distilled-600M
HF_TOKEN=

# AI worker (celery-worker-ai). With docker-compose.gpu.yml use cuda + STT_COMPUTE_TYPE=float16
STT_DEVICE=cpu
STT_COMPUTE_TYPE=auto
SILMA_DEVICE=cpu
