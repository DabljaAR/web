# Caddy / domain
DOMAIN=example.com
ACME_EMAIL=ops@example.com

# Core security
SECRET_KEY=replace-with-long-random-secret

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=dabljaar

# MinIO
MINIO_ROOT_USER=replace-with-access-key
MINIO_ROOT_PASSWORD=replace-with-secret-key
MINIO_BUCKET_NAME=dablaja-videos

# Optional auth tuning
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI runtime defaults (CPU first)
STT_DEVICE=cpu
HABIBI_DEVICE=cpu

# NMT model — MinIO bucket + key where your fine-tuned model is stored
# The model is downloaded to the nmt_model_cache volume on first start.
NMT_MODEL_BUCKET=model
NMT_MODEL_KEY=nmt-v4
# Override if you rename the cache volume mount point
NMT_MODEL_LOCAL_PATH=/model-cache/nmt-v4
# HuggingFace fallback (used only if MinIO download fails)
NMT_HF_FALLBACK=facebook/nllb-200-distilled-600M
# Optional: HuggingFace token for private/gated models
HF_TOKEN=
