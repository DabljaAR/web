# Copy to .env.production and fill in secrets. Used by:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production
# Keep .env.production out of version control.

# =============================================================================
# Caddy / domain
# =============================================================================
DOMAIN=example.com
ACME_EMAIL=ops@example.com
# Flower admin dashboard basic auth (user:password). DNS: point minio.DOMAIN and flower.DOMAIN to this host for TLS.
FLOWER_BASIC_AUTH=admin:replace-with-strong-password
# Optional: broker inspect timeout in ms (workers must be running; AI worker cold start can need 10–30s).
# FLOWER_INSPECT_TIMEOUT=30000

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=dabljaar

# =============================================================================
# MinIO (in-stack container credentials; compose maps these to MINIO_ACCESS_KEY / MINIO_SECRET_KEY for app workers)
# =============================================================================
MINIO_ROOT_USER=replace-with-access-key
MINIO_ROOT_PASSWORD=replace-with-secret-key
MINIO_BUCKET_NAME=dablaja-videos
# Optional explicit buckets (defaults: media = MINIO_BUCKET_NAME or dablaja-videos, models = model)
S3_MEDIA_BUCKET=
S3_MODELS_BUCKET=

# =============================================================================
# Object storage — optional overrides for external S3/GCP
# docker-compose.prod.yml passes these into backend + celery-worker-media + celery-worker-ai.
# =============================================================================
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
# If the secret contains + or /, wrap the value in double quotes in .env files.
S3_SECRET_ACCESS_KEY=
# GCS HMAC SigV4: use us-east-1 (GCS convention). AWS S3: use your bucket region.
S3_REGION=us-east-1
S3_SECURE=false

# =============================================================================
# Celery workers (concurrency passed to docker compose worker commands)
# =============================================================================
MEDIA_WORKER_CONCURRENCY=2
AI_WORKER_CONCURRENCY=1

# =============================================================================
# NMT — object prefix under S3_MODELS_BUCKET (cached under nmt_model_cache volume on first start)
# =============================================================================
NMT_MODEL_KEY=nmt-v4
NMT_MODEL_LOCAL_PATH=/model-cache/nmt-v4
NMT_HF_FALLBACK=facebook/nllb-200-distilled-600M
HF_TOKEN=
HF_HUB_DISABLE_XET=1
HF_HUB_DOWNLOAD_TIMEOUT=120

# Keep caches/models under writable mounted storage for non-root workers.
HF_HOME=/model-cache/hf
HUGGINGFACE_HUB_CACHE=/model-cache/hf/hub
TRANSFORMERS_CACHE=/model-cache/hf/transformers
XDG_CACHE_HOME=/model-cache/xdg-cache
TORCH_HOME=/model-cache/torch
CATT_TASHKEEL_MODEL_DIR=/model-cache/catt_tashkeel/onnx_models

# =============================================================================
# STT (Whisper / faster-whisper) — prefix under S3_MODELS_BUCKET, then HuggingFace by STT_MODEL_SIZE
# With docker-compose.gpu.yml use cuda + STT_COMPUTE_TYPE=float16
# =============================================================================
STT_MODEL_SIZE=small
STT_MODEL_KEY=whisper-small
STT_MODEL_LOCAL_PATH=/model-cache/whisper-small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=auto

# =============================================================================
# TTS / SILMA — SILMA_REFERENCE_AUDIO: container filesystem path OR S3 object key in S3_MEDIA_BUCKET
# =============================================================================
SILMA_DEVICE=cpu
SILMA_REFERENCE_AUDIO=
SILMA_REFERENCE_TEXT=ويدقق النظر في القرآن الكريم وسائر الكتب السماوية ويتبع مسالك الرسل العظام عليهم الصلاة والسلام.
TTS_DEFAULT_SPEED=0.9
TTS_DEFAULT_CFG_STRENGTH=2.0
TTS_DEFAULT_NFE_STEP=64
TTS_DEFAULT_SWAY_COEF=-1.0
TTS_DEFAULT_TARGET_RMS=0.12
